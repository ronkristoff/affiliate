{
  "name": "salig-affiliate",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "convex": "^1.32.0",
      "better-auth": "1.4.9",
      "@convex-dev/better-auth": "^0.10.13",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @salig-affiliate/backend dev",
    "dev:setup": "turbo -F @salig-affiliate/backend dev:setup"
  },
  "dependencies": {
    "@salig-affiliate/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@salig-affiliate/config": "workspace:*",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.2.21"
}
